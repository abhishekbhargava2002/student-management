{
  "info": {
    "name": "Student Management System API",
    "description": "Node.js + Express.js + PostgreSQL machine test API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "studentId",
      "value": "1"
    },
    {
      "key": "courseId",
      "value": "1"
    },
    {
      "key": "markId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) { pm.collectionVariables.set('token', json.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Amit\",\n  \"last_name\": \"Verma\",\n  \"email\": \"amit.verma@example.com\",\n  \"phone\": \"9988776655\",\n  \"date_of_birth\": \"2001-04-15\",\n  \"gender\": \"MALE\",\n  \"address\": \"Mumbai\"\n}"
            },
            "url": "{{baseUrl}}/students"
          }
        },
        {
          "name": "Get Students With Pagination",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students?page=1&limit=5&search="
          }
        },
        {
          "name": "Get Student By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}"
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Amit\",\n  \"last_name\": \"Updated\",\n  \"phone\": \"9000000000\",\n  \"address\": \"Pune\"\n}"
            },
            "url": "{{baseUrl}}/students/{{studentId}}"
          }
        },
        {
          "name": "Assign Course To Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/courses/{{courseId}}"
          }
        },
        {
          "name": "Get Student Marks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/marks"
          }
        },
        {
          "name": "Get Student Mark By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/marks/{{markId}}"
          }
        },
        {
          "name": "Create Student Marks",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/marks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": 1,\n  \"exam_name\": \"Final Exam\",\n  \"marks_obtained\": 88,\n  \"max_marks\": 100,\n  \"exam_date\": \"2026-06-20\"\n}"
            }
          }
        },
        {
          "name": "Update Student Marks",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/marks/{{markId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": 1,\n  \"exam_name\": \"Final Exam\",\n  \"marks_obtained\": 91,\n  \"max_marks\": 100,\n  \"exam_date\": \"2026-06-22\"\n}"
            }
          }
        },
        {
          "name": "Delete Student Marks",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/marks/{{markId}}"
          }
        },
        {
          "name": "Remove Assigned Course",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}/courses/{{courseId}}"
          }
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/students/{{studentId}}"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_code\": \"NODE101\",\n  \"name\": \"Node.js Backend Development\",\n  \"description\": \"Express.js APIs with PostgreSQL\",\n  \"credits\": 4\n}"
            },
            "url": "{{baseUrl}}/courses"
          }
        },
        {
          "name": "Get Courses With Pagination",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/courses?page=1&limit=10&search="
          }
        },
        {
          "name": "Get Course By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/courses/{{courseId}}"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Advanced Node.js Backend Development\",\n  \"credits\": 5,\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/courses/{{courseId}}"
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/courses/{{courseId}}"
          }
        }
      ]
    }
  ]
}